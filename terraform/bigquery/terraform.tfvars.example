# ─── dbt Platform ───────────────────────────────────────────────────────────────
dbt_account_id = 000                          # REPLACE: your dbt Platform account ID
dbt_host_url   = "https://emea.dbt.com/api"  # REPLACE: see docs/regions.md

# ─── Project ─────────────────────────────────────────────────────────────────
project_name = "my_project"                   # REPLACE
dbt_version  = "versionless"

# ─── Git repository ──────────────────────────────────────────────────────────
git_remote_url         = "git@github.com:MY_ORG/MY_REPO.git"  # REPLACE
git_clone_strategy     = "github_app"
github_installation_id = 000000000            # REPLACE: see docs/find-github-installation-id.md

# ─── BigQuery connection ─────────────────────────────────────────────────────
gcp_project_id     = "MY_GCP_PROJECT"         # REPLACE
gcp_location       = "US"                     # REPLACE: US, EU, us-central1, etc.
bigquery_client_email      = "sa@my-project.iam.gserviceaccount.com"  # REPLACE
bigquery_client_id         = "000000000000000000000"                   # REPLACE
bigquery_client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/sa%40my-project.iam.gserviceaccount.com"  # REPLACE

# ─── Environments / datasets ────────────────────────────────────────────────
schema_prefix      = "dbt_myproject"          # REPLACE: datasets = {prefix}_dev / {prefix}_staging / {prefix}_prod
schema_development = "dev"
schema_staging     = "staging"
schema_production  = "prod"

# ─── Jobs ────────────────────────────────────────────────────────────────────
daily_job_schedule_hours = [6]                # UTC hour for the daily build

# ─── SENSITIVE — never commit these ──────────────────────────────────────────
# Set as environment variables before running terraform:
#   export TF_VAR_dbt_token="dbtc_..."
#   export TF_VAR_bigquery_private_key_id="..."
#   export TF_VAR_bigquery_private_key="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
