# Copy this file to .env and fill in your credentials
# cp .env.example .env && chmod 600 .env

# ─── dbt Platform ────────────────────────────────────────────────────────────────
# Account Admin service token from dbt Platform → Account Settings → Service Tokens
export TF_VAR_dbt_token="dbtc_..."

# ─── Warehouse (uncomment the section matching your auth_method) ─────────────

# Snowflake (password):
export TF_VAR_snowflake_password="..."

# Snowflake (keypair):
# export TF_VAR_snowflake_private_key="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# export TF_VAR_snowflake_private_key_passphrase="..."   # optional

# BigQuery (service_account):
# export TF_VAR_bigquery_private_key_id="..."
# export TF_VAR_bigquery_private_key="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Databricks (token / PAT):
# export TF_VAR_databricks_token="dapi..."

# Databricks (oauth / service principal):
# export TF_VAR_databricks_client_id="..."
# export TF_VAR_databricks_client_secret="..."

# ─── Git Provider (uncomment the section matching your git.provider) ─────────

# GitHub — uses gh CLI (already authenticated), no extra token needed
# gh auth refresh -h github.com -s admin:org   ← run once if not already granted
export GITHUB_ORG=""   # org name, or "" for personal account

# GitLab:
# export TF_VAR_gitlab_deploy_token_username="deploy-token-username"
# export TF_VAR_gitlab_deploy_token="gldt-xxxxxxxxxxxx"

# Azure DevOps:
# export TF_VAR_azure_ad_app_client_id="..."
# export TF_VAR_azure_ad_app_client_secret="..."

# ─── MCP Server (auto-generated by dbt-infra agent after Phase 6) ────────────
# This token is created by Terraform (dbtcloud_service_token.mcp) with permissions:
# metadata_only + semantic_layer_only + job_admin + developer
# export DBT_MCP_TOKEN="dbtc_..."   # ← added automatically by dbt-infra agent
